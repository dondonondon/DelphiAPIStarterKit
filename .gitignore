# Delphi compiler-generated binaries
*.exe
*.dll
*.bpl
*.bpi
*.dcp
*.so
*.apk
*.drc
*.map
*.dres
*.rsm
*.tds
*.dcu
*.lib
*.a
*.o
*.ocx

# Delphi autogenerated files
*.cfg
*.hpp
*Resource.rc

# Delphi local files (user-specific)
*.local
*.identcache
*.projdata
*.tvsconfig
*.dsk
*.dsv

# Delphi history and backups
__history/
__recovery/
*.~*

# Castalia statistics (since XE7)
*.stat

# Local runtime configuration and secrets
config.ini
.env

# Repository-specific ignores
/.github/
/AGENTS.md
/docs/*

# Boss dependency manager (https://github.com/HashLoad/boss)
/modules/

# Generated DataSnap proxy output
/bin/proxy/
/proxy/

# Runtime file storage
/bin/files/

# Native client library (users install from official vendor)
/bin/lib/*.dll

# Legacy snapshot directory
/temp-file/

# Empty directory placeholders
sources/shared/types/.gitkeep
sources/shared/middleware/.gitkeep
sources/tests/integration/.gitkeep
sources/tests/unit/.gitkeep
sources/infrastructure/external/.gitkeep
sources/infrastructure/security/.gitkeep
sources/infrastructure/logging/.gitkeep

# Unignored exceptions
!libmysql.dll
!/docs/databases/
!/docs/information/
!/docs/api/
